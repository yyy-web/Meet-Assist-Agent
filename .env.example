# API Keys - 请替换为你自己的密钥
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Boss 直聘爬虫配置
BOSS_HEADLESS=0
BOSS_USE_REAL_SCRAPER=1
BOSS_MAX_PAGES=1
BOSS_FETCH_DETAIL=1

